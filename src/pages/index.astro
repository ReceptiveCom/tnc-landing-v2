---
// TNC Landing Page
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Your Personal Dietitian — Covered by Insurance | Top Nutrition Coaching</title>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400;1,500;1,600;1,700&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300;1,400&display=swap" rel="stylesheet">
<style>
  :root {
    --forest: #1C4A36;
    --forest-deep: #122E22;
    --sapien: #547668;
    --leaf: #6BAD5A;
    --mint: #EDF5F1;
    --mint-light: #F6FAF8;
    --bloom: #FF5C3B;
    --bloom-hover: #E84D2C;
    --bloom-glow: rgba(255, 92, 59, 0.15);
    --dark: #1A1A1A;
    --dark-soft: #3D3D3D;
    --grey: #6B6B6B;
    --grey-light: #F4F4F0;
    --border: rgba(28, 74, 54, 0.08);
    --white: #FFFFFF;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;
    color: var(--dark);
    background: var(--white);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    overflow-x: hidden;
  }

  h1, h2, h3, h4 {
    font-family: 'Plus Jakarta Sans', sans-serif;
    letter-spacing: -0.025em;
    line-height: 1.12;
  }

  /* Fade-in on scroll */
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1), transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ==================== NAV ==================== */
  .nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: rgba(255,255,255,0.92);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(0,0,0,0.04);
  }
  .nav-inner {
    max-width: 1140px; margin: 0 auto;
    display: flex; align-items: center; justify-content: space-between;
    height: 60px; padding: 0 24px;
  }
  .nav-logo {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 800; font-size: 17px; color: var(--forest);
    text-decoration: none; letter-spacing: -0.04em;
    display: flex; flex-direction: column; line-height: 1;
  }
  .nav-logo-sub {
    font-size: 9px; font-weight: 500; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--sapien); margin-top: 1px;
  }
  .nav-right { display: flex; align-items: center; gap: 20px; }
  .nav-link {
    font-size: 14px; color: var(--dark-soft); text-decoration: none;
    font-weight: 500;
  }
  .nav-link:hover { color: var(--dark); }
  .btn {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 700; font-size: 14px;
    border: none; cursor: pointer; text-decoration: none;
    transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .btn-bloom {
    background: var(--bloom); color: white;
    padding: 11px 22px; border-radius: 10px;
    box-shadow: 0 2px 8px var(--bloom-glow);
  }
  .btn-bloom:hover {
    background: var(--bloom-hover);
    transform: translateY(-1px);
    box-shadow: 0 4px 16px var(--bloom-glow);
  }
  .btn-bloom-lg {
    padding: 16px 36px; font-size: 16px; border-radius: 14px;
    box-shadow: 0 4px 20px var(--bloom-glow);
  }
  .btn-bloom-lg:hover { box-shadow: 0 8px 28px rgba(255,92,59,0.25); }
  .btn svg { width: 16px; height: 16px; }

  /* ==================== HERO ==================== */
  .hero {
    padding: 112px 24px 0;
    background: var(--white);
    position: relative;
    overflow: hidden;
  }
  /* Soft organic shape in background */
  .hero::before {
    content: '';
    position: absolute;
    top: -40%; right: -10%;
    width: 70vw; height: 70vw; max-width: 800px; max-height: 800px;
    background: radial-gradient(ellipse at center, var(--mint) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }
  .hero-inner {
    max-width: 1140px; margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
    position: relative; z-index: 1;
    min-height: calc(100vh - 112px - 80px);
  }
  .hero-content {
    padding: 40px 0 80px;
  }
  .hero-pill {
    display: inline-flex; align-items: center; gap: 8px;
    background: var(--mint); border: 1px solid var(--border);
    padding: 7px 16px; border-radius: 100px;
    font-size: 13px; font-weight: 600; color: var(--forest);
    margin-bottom: 28px;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .hero-pill-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--leaf);
    animation: pulse-dot 2s ease-in-out infinite;
  }
  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
  .hero h1 {
    font-size: clamp(38px, 4.8vw, 58px);
    font-weight: 800;
    color: var(--dark);
    margin-bottom: 20px;
  }
  .hero h1 em {
    font-style: italic;
    color: var(--forest);
    font-weight: 700;
  }
  .hero-sub {
    font-size: 17px; line-height: 1.65;
    color: var(--grey);
    margin-bottom: 36px;
    max-width: 420px;
  }
  .hero-cta-row {
    display: flex; flex-direction: column; gap: 10px; align-items: flex-start;
  }
  .hero-cta-note {
    font-size: 13px; color: var(--grey); padding-left: 4px;
  }
  .hero-cta-note strong { color: var(--dark-soft); font-weight: 600; }

  /* Hero visual — image placeholder + floating proof card */
  .hero-visual {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: flex-end;
    padding-bottom: 0;
  }
  .hero-img-wrap {
    width: 100%;
    max-width: 480px;
    aspect-ratio: 4 / 5;
    background: linear-gradient(160deg, var(--mint) 0%, #D6E8DD 100%);
    border-radius: 32px 32px 0 0;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }
  /* Simulated warm portrait silhouette */
  .hero-img-placeholder {
    width: 75%;
    height: 85%;
    background: linear-gradient(180deg, rgba(28,74,54,0.06) 0%, rgba(28,74,54,0.12) 100%);
    border-radius: 24px 24px 0 0;
    position: relative;
  }
  .hero-img-label {
    position: absolute;
    bottom: 20px; left: 50%;
    transform: translateX(-50%);
    background: rgba(255,255,255,0.9);
    backdrop-filter: blur(8px);
    padding: 8px 16px;
    border-radius: 10px;
    font-size: 12px;
    font-weight: 600;
    color: var(--forest);
    font-family: 'Plus Jakarta Sans', sans-serif;
    white-space: nowrap;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  }
  /* Floating proof card */
  .hero-float-card {
    position: absolute;
    bottom: 80px; left: -36px;
    background: var(--white);
    border-radius: 16px;
    padding: 18px 22px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.08), 0 1px 3px rgba(0,0,0,0.04);
    max-width: 260px;
    animation: float-subtle 4s ease-in-out infinite;
    z-index: 2;
  }
  @keyframes float-subtle {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }
  .hero-float-quote {
    font-size: 13px; line-height: 1.55;
    color: var(--dark-soft);
    font-style: italic;
    margin-bottom: 10px;
  }
  .hero-float-attr {
    display: flex; align-items: center; gap: 8px;
  }
  .hero-float-avatar {
    width: 28px; height: 28px; border-radius: 50%;
    background: var(--mint);
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 700; color: var(--forest);
  }
  .hero-float-name {
    font-size: 12px; font-weight: 600; color: var(--dark);
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .hero-float-detail {
    font-size: 11px; color: var(--grey);
  }
  /* Floating stat card */
  .hero-stat-card {
    position: absolute;
    top: 60px; right: -20px;
    background: var(--forest);
    color: white;
    border-radius: 14px;
    padding: 16px 20px;
    box-shadow: 0 8px 24px rgba(28,74,54,0.2);
    z-index: 2;
    animation: float-subtle 4s ease-in-out infinite 1s;
    text-align: center;
  }
  .hero-stat-num {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 800; font-size: 28px; line-height: 1;
  }
  .hero-stat-label {
    font-size: 11px; color: rgba(255,255,255,0.7);
    margin-top: 4px; font-weight: 500;
  }

  /* ==================== INSURANCE BAR ==================== */
  .logo-bar {
    padding: 28px 24px;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    background: var(--white);
  }
  .logo-bar-inner {
    max-width: 1140px; margin: 0 auto;
    display: flex; align-items: center; justify-content: center;
    gap: 40px; flex-wrap: wrap;
  }
  .logo-bar-label {
    font-size: 11px; text-transform: uppercase;
    letter-spacing: 0.1em; color: var(--grey);
    font-weight: 600; font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .logo-bar-items { display: flex; gap: 32px; align-items: center; flex-wrap: wrap; justify-content: center; }
  .logo-bar-item {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 800; font-size: 15px; color: var(--dark);
    opacity: 0.3; letter-spacing: -0.02em;
  }

  /* ==================== SECTION UTILITIES ==================== */
  .section { padding: 96px 24px; }
  .section-inner { max-width: 1140px; margin: 0 auto; }
  .section-label {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 11px; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.1em;
    color: var(--sapien);
    margin-bottom: 12px;
  }
  .section-h2 {
    font-size: clamp(30px, 3.6vw, 44px);
    font-weight: 800; margin-bottom: 16px;
  }
  .section-sub {
    font-size: 17px; color: var(--grey);
    line-height: 1.6; max-width: 520px;
  }
  .section-sub.centered { margin: 0 auto; text-align: center; }
  .text-center { text-align: center; }

  /* ==================== HOW IT WORKS ==================== */
  .how { background: var(--mint-light); }
  .how-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 20px; margin-top: 56px;
  }
  .how-card {
    background: var(--white);
    border-radius: 20px;
    padding: 36px 28px;
    border: 1px solid var(--border);
    position: relative;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .how-card:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(0,0,0,0.04); }
  .how-num {
    width: 36px; height: 36px; border-radius: 10px;
    background: var(--forest); color: white;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 800; font-size: 15px;
    margin-bottom: 20px;
  }
  .how-card h3 {
    font-size: 19px; font-weight: 700;
    margin-bottom: 10px;
  }
  .how-card p {
    font-size: 15px; color: var(--grey);
    line-height: 1.6;
  }
  .how-time {
    margin-top: 20px;
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 12px; font-weight: 600; color: var(--sapien);
    font-family: 'Plus Jakarta Sans', sans-serif;
    background: var(--mint); padding: 5px 12px; border-radius: 8px;
  }

  /* ==================== EMOTIONAL / VOICES ==================== */
  .voices { background: var(--forest); color: white; padding: 100px 24px; position: relative; overflow: hidden; }
  .voices::before {
    content: '';
    position: absolute; top: -50%; left: -20%;
    width: 80vw; height: 80vw;
    background: radial-gradient(circle, rgba(107,173,90,0.08) 0%, transparent 60%);
    border-radius: 50%;
  }
  .voices .section-inner { position: relative; z-index: 1; }
  .voices .section-label { color: rgba(255,255,255,0.4); }
  .voices .section-h2 { color: white; max-width: 600px; }
  .voices .section-sub { color: rgba(255,255,255,0.6); margin-bottom: 56px; }
  .voice-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .v-card {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 20px;
    padding: 28px 24px;
    transition: background 0.3s;
  }
  .v-card:hover { background: rgba(255,255,255,0.1); }
  .v-card p {
    font-size: 15px; line-height: 1.65;
    color: rgba(255,255,255,0.88);
    font-style: italic;
    margin-bottom: 20px;
  }
  .v-attr-name {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 13px; font-weight: 700; color: white;
  }
  .v-attr-detail {
    font-size: 12px; color: rgba(255,255,255,0.4);
    margin-top: 2px;
  }

  /* ==================== DIETITIANS ==================== */
  .dietitians { background: var(--white); }
  .rd-badge {
    display: inline-flex; align-items: center; gap: 8px;
    background: var(--forest); color: white;
    padding: 7px 16px; border-radius: 100px;
    font-size: 13px; font-weight: 600;
    font-family: 'Plus Jakarta Sans', sans-serif;
    margin-top: 20px;
  }
  .rd-grid {
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 18px; margin-top: 48px;
  }
  .rd-card {
    border-radius: 20px; overflow: hidden;
    border: 1px solid var(--border);
    background: var(--white);
    transition: transform 0.25s, box-shadow 0.25s;
  }
  .rd-card:hover { transform: translateY(-6px); box-shadow: 0 12px 32px rgba(0,0,0,0.06); }
  .rd-photo {
    width: 100%; aspect-ratio: 1;
    background: linear-gradient(135deg, var(--mint) 0%, #D4E6DA 100%);
    display: flex; align-items: center; justify-content: center;
    font-size: 56px;
    position: relative;
  }
  .rd-photo::after {
    content: '';
    position: absolute; bottom: 0; left: 0; right: 0;
    height: 48px;
    background: linear-gradient(transparent, white);
  }
  .rd-body { padding: 18px 20px 22px; }
  .rd-name {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 700; font-size: 16px; color: var(--dark);
    margin-bottom: 2px;
  }
  .rd-cred {
    font-size: 12px; color: var(--forest); font-weight: 600;
    margin-bottom: 10px;
  }
  .rd-spec { font-size: 13px; color: var(--grey); line-height: 1.5; }
  .rd-tags { display: flex; flex-wrap: wrap; gap: 5px; margin-top: 12px; }
  .rd-tag {
    background: var(--mint); color: var(--forest);
    font-size: 11px; font-weight: 600;
    padding: 3px 10px; border-radius: 6px;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }

  /* ==================== RESULTS / STORIES ==================== */
  .results { background: var(--grey-light); }
  .story-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 20px; margin-top: 48px;
  }
  .s-card {
    background: var(--white);
    border-radius: 20px;
    padding: 32px;
    border: 1px solid var(--border);
  }
  .s-header {
    display: flex; align-items: center; gap: 12px;
    margin-bottom: 18px;
  }
  .s-avatar {
    width: 44px; height: 44px; border-radius: 50%;
    background: var(--mint);
    display: flex; align-items: center; justify-content: center;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 700; font-size: 15px; color: var(--forest);
    flex-shrink: 0;
  }
  .s-name {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 700; font-size: 15px;
  }
  .s-ctx { font-size: 12px; color: var(--grey); margin-top: 1px; }
  .s-quote {
    font-size: 15px; line-height: 1.65; color: var(--dark-soft);
    margin-bottom: 18px;
  }
  .s-outcome {
    display: inline-flex; align-items: center; gap: 6px;
    background: var(--forest); color: white;
    padding: 6px 14px; border-radius: 10px;
    font-size: 13px; font-weight: 600;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }

  /* ==================== INSURANCE DETAIL ==================== */
  .insurance-deep { background: var(--white); }
  .ins-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 64px; align-items: center;
  }
  .ins-stats {
    display: flex; gap: 40px; margin: 28px 0 36px;
  }
  .ins-stat-num {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 800; font-size: 40px; color: var(--forest);
    line-height: 1;
  }
  .ins-stat-label { font-size: 13px; color: var(--grey); margin-top: 4px; }
  .ins-visual {
    background: var(--mint-light);
    border-radius: 24px;
    padding: 40px;
  }
  .ins-logos-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .ins-logo-card {
    background: var(--white);
    border-radius: 12px;
    padding: 18px 16px;
    text-align: center;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 800; font-size: 14px; color: var(--dark);
    opacity: 0.5;
    box-shadow: 0 1px 4px rgba(0,0,0,0.04);
  }
  .ins-cta-note {
    font-size: 14px; color: var(--grey);
    margin-top: 12px;
  }

  /* ==================== FAQ ==================== */
  .faq { background: var(--grey-light); }
  .faq-list {
    max-width: 680px; margin: 48px auto 0;
    display: flex; flex-direction: column; gap: 6px;
  }
  .faq-item {
    background: var(--white);
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid var(--border);
  }
  .faq-q {
    padding: 20px 24px;
    cursor: pointer;
    display: flex; align-items: center; justify-content: space-between;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 600; font-size: 15px; color: var(--dark);
    background: none; border: none; width: 100%; text-align: left;
    transition: background 0.2s;
  }
  .faq-q:hover { background: var(--mint-light); }
  .faq-icon {
    width: 24px; height: 24px; border-radius: 50%;
    background: var(--mint);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    transition: transform 0.3s, background 0.3s;
  }
  .faq-icon svg { width: 14px; height: 14px; color: var(--forest); }
  .faq-item.open .faq-icon { transform: rotate(45deg); background: var(--forest); }
  .faq-item.open .faq-icon svg { color: white; }
  .faq-a {
    max-height: 0; overflow: hidden;
    transition: max-height 0.35s ease, padding 0.35s ease;
    padding: 0 24px;
    font-size: 15px; color: var(--grey); line-height: 1.65;
  }
  .faq-item.open .faq-a {
    max-height: 300px;
    padding: 0 24px 22px;
  }

  /* ==================== FINAL CTA ==================== */
  .final-cta {
    background: var(--mint);
    padding: 100px 24px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .final-cta::before {
    content: '';
    position: absolute; bottom: -40%; right: -20%;
    width: 60vw; height: 60vw;
    background: radial-gradient(circle, rgba(28,74,54,0.05) 0%, transparent 60%);
    border-radius: 50%;
  }
  .final-cta .section-inner { position: relative; z-index: 1; }
  .final-cta .section-h2 { margin-bottom: 12px; }
  .final-cta p {
    font-size: 17px; color: var(--grey);
    max-width: 460px; margin: 0 auto 36px;
    line-height: 1.6;
  }
  .trust-row {
    display: flex; align-items: center; justify-content: center;
    gap: 20px; flex-wrap: wrap; margin-top: 28px;
  }
  .trust-item {
    display: flex; align-items: center; gap: 6px;
    font-size: 13px; color: var(--grey); font-weight: 500;
  }
  .trust-check {
    width: 18px; height: 18px; border-radius: 50%;
    background: var(--forest);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .trust-check svg { width: 10px; height: 10px; color: white; }

  /* ==================== FOOTER ==================== */
  .footer {
    background: var(--dark); color: rgba(255,255,255,0.4);
    padding: 40px 24px; text-align: center; font-size: 13px;
  }
  .footer a { color: rgba(255,255,255,0.6); text-decoration: none; }

  /* ==================== RESPONSIVE ==================== */
  @media (max-width: 960px) {
    .hero-inner { grid-template-columns: 1fr; gap: 32px; }
    .hero-content { padding: 32px 0 0; }
    .hero-visual { max-width: 400px; margin: 0 auto; }
    .how-grid { grid-template-columns: 1fr; }
    .voice-grid { grid-template-columns: 1fr; }
    .rd-grid { grid-template-columns: 1fr 1fr; }
    .story-grid { grid-template-columns: 1fr; }
    .ins-grid { grid-template-columns: 1fr; gap: 40px; }
  }
  @media (max-width: 640px) {
    .hero { padding-top: 88px; }
    .hero h1 { font-size: 32px; }
    .section { padding: 72px 20px; }
    .voices { padding: 72px 20px; }
